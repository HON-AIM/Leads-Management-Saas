# Lead Distribution System - Environment Variables

# MongoDB Connection
# Local: mongodb://localhost:27017/lead-distribution
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/lead-distribution
MONGO_URI=mongodb://localhost:27017/lead-distribution

# Server Port
PORT=5000

# JWT Secret Key (change this in production!)
JWT_SECRET=your-secret-key-change-in-production

# Email Configuration (Gmail SMTP)
# Use App Password for Gmail (not your regular password)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Optional: Frontend API URL (for production)
# VITE_API_URL=https://your-backend-url.com/api
