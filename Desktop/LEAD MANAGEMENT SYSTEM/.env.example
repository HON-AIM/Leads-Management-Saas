# Lead Distribution System - Environment Variables

# MongoDB Connection
# Local: mongodb://localhost:27017/lead-distribution
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/lead-distribution
MONGO_URI=mongodb://localhost:27017/lead-distribution

# Server Port
PORT=5000

# JWT Secret Key (REQUIRED in production!)
JWT_SECRET=your-secret-key-change-in-production

# Email Configuration (Gmail SMTP)
# Use App Password for Gmail (not your regular password)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# CORS Allowed Origins (REQUIRED in production!)
# Separate multiple origins with commas, no spaces
# Examples:
#   ALLOWED_ORIGINS=https://yourfrontend.vercel.app
#   ALLOWED_ORIGINS=https://example.com,https://www.example.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
