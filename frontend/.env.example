# Lead Distribution System - Frontend Environment Variables

# Backend API URL (for production deployments)
# Leave empty for same-origin deployment (Docker/nginx proxy)
# Examples:
#   VITE_API_URL=https://api.yourdomain.com/api
#   VITE_API_URL=https://your-backend.onrender.com/api
VITE_API_URL=

# Optional: Set to 'true' to enable debug mode
# VITE_DEBUG=false
