# Lead Distribution SaaS - Multi-Tenant Environment Variables

# Database Configuration
MONGO_URI=mongodb://localhost:27017/lead-distribution-saas

# JWT Secrets (Generate strong random strings - minimum 32 characters)
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=your-super-secure-access-secret-key-32-chars-minimum
JWT_REFRESH_SECRET=your-super-secure-refresh-secret-key-32-chars-minimum
JWT_SECRET=fallback-secret-for-legacy-compatibility-only

# Server Configuration
PORT=5000
NODE_ENV=development

# Email Configuration (for notifications, verification, password reset)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password-or-oauth-token
FROM_EMAIL=noreply@yourapp.com

# Frontend Configuration
FRONTEND_URL=http://localhost:5173

# CORS Configuration (comma-separated allowed origins)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# OpenAI Configuration (optional - AI Assistant uses mock mode without this)
OPENAI_API_KEY=sk-your-openai-api-key
AI_MODEL=gpt-4o-mini
AI_MAX_TOKENS=2048
AI_TEMPERATURE=0.3

# Security Configuration
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_TIME_MINUTES=120

# Optional: Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Optional: File Upload
MAX_FILE_SIZE=5242880
# Examples:
#   ALLOWED_ORIGINS=https://yourfrontend.vercel.app
#   ALLOWED_ORIGINS=https://example.com,https://www.example.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
