# Lead Distribution SaaS - Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Database Configuration
# MongoDB Atlas connection string (Settings > Connect > Connect your application)
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/lead-distribution

# JWT Secrets
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# You need two separate random values — one for access tokens, one for refresh tokens.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend Configuration
# The URL your frontend is served from (used for CORS and redirects)
FRONTEND_URL=http://localhost:5173

# CORS Configuration (comma-separated allowed origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Email Configuration (Gmail SMTP)
# Use a Gmail App Password (not your regular password).
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_USER=
EMAIL_PASS=

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Lead Ingestion Configuration
DEDUP_WINDOW_HOURS=24
INGESTION_RATE_LIMIT=100

# Delivery Engine Configuration
# GoHighLevel API credentials (if using GHL as a delivery destination)
GHL_API_KEY=
GHL_LOCATION_ID=
DELIVERY_MAX_RETRIES=3
DELIVERY_INITIAL_DELAY_MS=2000
DELIVERY_TIMEOUT_MS=30000

# OpenAI Configuration (for AI-powered features)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_MAX_TOKENS=2048
AI_TEMPERATURE=0.3

# Security Configuration
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_TIME_MINUTES=120
